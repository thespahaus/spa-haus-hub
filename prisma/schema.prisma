// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  STAFF
}

enum PipelineStage {
  LEAD
  CONTACTED
  QUOTED
  NEGOTIATING
  CUSTOMER
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STATUS_CHANGE
  TASK
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum ShellColor {
  SILVER_MARBLE
  STORM_CLOUDS
  TUSCAN_SUN
  SMOKEY_MOUNTAINS
  MIDNIGHT_CANYON
}

enum CabinetColor {
  MODERN_MOCHA
  CHARCOAL
  LIGHT_FOG
}

enum Voltage {
  V110
  V220_240
}

enum Sanitizer {
  BROMINE
  CHLORINE
}

enum PaymentMethod {
  CASH_CHECK
  DEBIT_ACH
  CREDIT_CARD
  WELLS_FARGO_FINANCING
}

enum InstallationStage {
  ORDERED
  SHIPPED
  RECEIVED_AT_SHOP
  READY_FOR_DELIVERY
  DELIVERED
  INSTALL_VISIT
  STARTUP_CALL
  COMPLETE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(STAFF)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  assignedTasks Task[]     @relation("AssignedTasks")
  createdTasks  Task[]     @relation("CreatedTasks")
  activities    Activity[]
  quotes        Quote[]    @relation("QuoteOwner")
  contacts      Contact[]  @relation("ContactOwner")
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  stage     PipelineStage @default(LEAD)
  source    String?
  ownerId   String?
  owner     User?         @relation("ContactOwner", fields: [ownerId], references: [id])

  // Forward-compat: unused in Phase 1, present to avoid a later migration
  qboCustomerId String? @unique
  externalIds   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes        Quote[]
  activities    Activity[]
  tasks         Task[]
  installations Installation[]
}

model Quote {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     User    @relation("QuoteOwner", fields: [ownerId], references: [id])

  title       String
  description String?
  amount      Decimal     @db.Decimal(10, 2)
  status      QuoteStatus @default(DRAFT)
  sentAt      DateTime?
  decidedAt   DateTime?

  // Product configuration, from the real Sales Agreement (sent via PandaDoc today)
  productModel  String?
  dimensions    String?
  shellColor    ShellColor?
  cabinetColor  CabinetColor?
  voltage       Voltage?
  sanitizer     Sanitizer?
  paymentMethod PaymentMethod?

  // Forward-compat: future integration sync targets
  qboEstimateId      String?   @unique
  qboSyncedAt        DateTime?
  pandaDocDocumentId String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installation Installation?
}

model Activity {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?   @relation(fields: [authorId], references: [id])

  type       ActivityType
  body       String
  source     String   @default("manual")
  externalId String?
  occurredAt DateTime @default(now())

  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(OPEN)

  assigneeId  String
  assignee    User   @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Installation {
  id        String  @id @default(cuid())
  quoteId   String  @unique
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  stage InstallationStage @default(ORDERED)

  scheduledDeliveryDate DateTime?
  deliveredAt           DateTime?

  // Site & electrical prep check-in — a single parallel confirmation point
  // (concrete/decking/electrical contractor lined up with a date), not a
  // sequential stage since it happens alongside production/shipping.
  prepConfirmed   Boolean   @default(false)
  prepConfirmedAt DateTime?
  prepNotes       String?

  // Install-visit header, filled in on-site during the after-sales visit
  visitDate     DateTime?
  arrivalTime   DateTime?
  departureTime DateTime?
  serialNumber  String?
  gfciBrand     String?
  gfciAmperage  String?

  // Delivery-confirmation checklist
  chemicalKitPresent        Boolean?
  coverLifterBoxPresent     Boolean?
  stepsBoxPresent           Boolean?
  coverClipsHardwarePresent Boolean?
  otherAccessoriesPresent   Boolean?
  waterFilled               Boolean?
  powerOn                   Boolean?

  // ~15 pass/fail checklist groups (Steps, Cover, Cover Lifter, Cover Clips, Initial
  // Startup, Topside Controls, Jet Pumps, Jets/Valves, Waterfalls, Lights &
  // Entertainment, Leak/Visual, Customer Handoff) — typed via a shared TS interface
  // rather than dozens of columns nothing filters or reports on individually.
  checklist Json?

  issuesNotes      String?
  photosTaken      Boolean?
  followUpWarranty Boolean @default(false)
  followUpService  Boolean @default(false)
  followUpParts    Boolean @default(false)

  installerSignedAt DateTime?
  customerSignedAt  DateTime?
  startupCallAt     DateTime?
  startupCallNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}
