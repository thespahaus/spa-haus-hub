// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  STAFF
}

enum PipelineStage {
  LEAD
  CONTACTED
  QUOTED
  NEGOTIATING
  CUSTOMER
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  STATUS_CHANGE
  TASK
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(STAFF)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  assignedTasks Task[]     @relation("AssignedTasks")
  createdTasks  Task[]     @relation("CreatedTasks")
  activities    Activity[]
  quotes        Quote[]    @relation("QuoteOwner")
  contacts      Contact[]  @relation("ContactOwner")
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  stage     PipelineStage @default(LEAD)
  source    String?
  ownerId   String?
  owner     User?         @relation("ContactOwner", fields: [ownerId], references: [id])

  // Forward-compat: unused in Phase 1, present to avoid a later migration
  qboCustomerId String? @unique
  externalIds   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  activities Activity[]
  tasks      Task[]
}

model Quote {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])
  ownerId   String
  owner     User    @relation("QuoteOwner", fields: [ownerId], references: [id])

  title       String
  description String?
  amount      Decimal     @db.Decimal(10, 2)
  status      QuoteStatus @default(DRAFT)
  sentAt      DateTime?
  decidedAt   DateTime?

  // Forward-compat: Phase 2 QBO sync target
  qboEstimateId String?   @unique
  qboSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Activity {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])
  authorId  String?
  author    User?   @relation(fields: [authorId], references: [id])

  type       ActivityType
  body       String
  source     String   @default("manual")
  externalId String?
  occurredAt DateTime @default(now())

  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(OPEN)

  assigneeId  String
  assignee    User   @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
